# macOS
.DS_Store

# Logs
*.log

# Editors
.idea/
.vscode/
.zed/
.cursor/

# TypeScript incremental build cache
*.tsbuildinfo

# Environment / secrets (defense in depth — coffeeproj/.gitignore already covers that subdir)
.env
.env.local
.env.*.local

# iOS signing — NEVER commit
*.p8
*.p12
*.mobileprovision

# Generic private keys / certificates — NEVER commit
*.pem
*.key
*.crt
*.cer
secrets/
credentials/

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# Claude Code: ignore everything under .claude/ except shared settings.json
# (covers settings.local.json, projects/, scheduled_tasks.lock, worktrees/, …)
.claude/*
!.claude/settings.json

# Test coverage
coverage/

# Ad-hoc dev/debug scripts (not meant to live in the repo)
/check_jobs.sql
/dev.sh
/test-db-query.js
coffeeproj/test-rls-check.js
coffeeproj/test-search-jobs.js
coffeeproj/test-search-detailed.js

# Internal docs and dev scripts — pending removal from history before making repo public.
# Files remain locally but should not be tracked going forward.
# See docs/pre-public-cleanup.md for the filter-repo procedure.
/ARCHITECTURE.md
/BUG_BACKLOG.md
/CLAUDE.md
/IMPLEMENTATION_PLAN.md
/PRD.md
coffeeproj/README.md
docs/push-notifications-setup.md
docs/testflight-setup.md
docs/resend-custom-domain.md
docs/pre-public-cleanup.md
coffeeproj/scripts/seed-simulation.js
coffeeproj/scripts/seed-test-jobs.js
